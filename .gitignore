# Local .terraform directories
**/.terraform/*

# .tfstate files containing infrastructure runtime secrets
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variable files since they might contain secrets
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS generated files
.DS_Store
.idea/
.vscode/
